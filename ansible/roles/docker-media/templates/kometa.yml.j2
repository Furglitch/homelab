playlist_files:
- file: /config/playlists/chronological.yml
  template_variables:
    libraries: Movies, TV Shows
    radarr_add_missing: false
    sonarr_add_missing: false

settings:
  run_order:
  - operations
  - collections
  - metadata
  - overlays
  cache: true
  cache_expiration: 30

  # Asset Management
  asset_directory:
  - /config/assets
  - /config
  asset_folders: true
  download_url_assets: true
  create_asset_folders: true
  prioritize_assets: true
  dimensional_asset_rename: false

  # Collection and Playlist Management
  minimum_items: 1
  default_collection_order: release
  delete_below_minimum: true
  delete_not_scheduled: false
  sync_mode: sync
  playlist_sync_to_users: all
  playlist_exclude_users:

  # Filtering
  missing_only_released: false
  only_filter_missing: false
  run_again_delay: 0

  # Log Outputs
  item_refresh_delay: 5
  show_missing_season_assets: false
  show_missing_episode_assets: false
  show_asset_not_needed: false
  show_unmanaged: false
  show_unconfigured: false
  show_filtered: false
  show_options: false
  show_missing: true
  show_missing_assets: false
  playlist_report: false
  save_report: false

  # Misc
  tvdb_language: default
  verify_ssl: true
  custom_repo:
  asset_depth: 0
  ignore_ids:
  ignore_imdb_ids:
  overlay_artwork_filetype: jpg
  overlay_artwork_quality:
  show_unfiltered: false


plex:
  url: http://{{ ip_local }}:{{ ports.plex }}
  token: {{ tokens.plex }}
  timeout: 60
  verify_ssl:
  db_cache:
  clean_bundles: false
  empty_trash: false
  optimize: false


radarr:
  url: http://{{ ip_local }}:{{ ports.radarr }}
  token: {{ tokens.radarr }}
  root_folder_path: /share/movies
  plex_path: /share/movies
  add_missing: true
  monitor: true
  quality_profile: TRaSH_WEB-1080p
  availability: released
  add_existing: false
  upgrade_existing: true
  monitor_existing: true
  ignore_cache: false
  tag:
  search: false
  radarr_path:


sonarr:
  url: http://{{ ip_local }}:{{ ports.sonarr }}
  token: {{ tokens.sonarr }}
  root_folder_path: /share/series
  plex_path: /share/series
  add_missing: true
  monitor: all
  quality_profile: TRaSH_WEB-720p
  availability: released
  language_profile: English
  series_type: standard
  season_folder: true
  add_existing: false
  upgrade_existing: true
  monitor_existing: true
  ignore_cache: false
  tag:
  search: false
  cutoff_search: false
  sonarr_path:


tmdb:
  apikey: {{ tokens.tmdb.api }}
  language: en
  region: US
  cache_expiration: 60


trakt: # https://metamanager.wiki/en/latest/config/trakt/#online-authorization
  client_id: {{ tokens.trakt.client_id }}
  client_secret: {{ tokens.trakt.client_secret }}
  authorization:
    access_token: {{ tokens.trakt.access_token }}
    token_type: Bearer
    expires_in: {{ tokens.trakt.expires_in }}
    refresh_token: {{ tokens.trakt.refresh_token }}
    scope: public
    created_at: {{ tokens.trakt.created_at }}
  pin: {{ tokens.trakt.pin }}

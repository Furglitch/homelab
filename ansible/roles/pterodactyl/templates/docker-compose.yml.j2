---
services:
    database:
        image: "mariadb:10.11"
        container_name: pterodactyl-db
        restart: unless-stopped
        command: --default-authentication-plugin=mysql_native_password
        volumes:
            - {{ files.data_path }}/pterodactyl/database:/var/lib/mysql
        environment:
            MYSQL_DATABASE: "{{ pterodactyl.db_name }}"
            MYSQL_USER: "{{ pterodactyl.db_user }}"
            MYSQL_PASSWORD: "{{ pterodactyl.db_password }}"
            MYSQL_ROOT_PASSWORD: "{{ pterodactyl.db_root_password }}"

    cache:
        image: "redis:alpine"
        container_name: pterodactyl-cache
        restart: unless-stopped

    panel:
        image: "ghcr.io/pterodactyl/panel:latest"
        container_name: pterodactyl-panel
        restart: unless-stopped
        depends_on:
            - database
            - cache
        ports:
            - "{{ ports.panel_http }}:80"
            - "{{ ports.panel_https }}:443"
        volumes:
            - {{ files.data_path }}/pterodactyl/panel/var:/app/var
            - {{ files.data_path }}/pterodactyl/panel/nginx:/etc/nginx/http.d/
            - {{ files.data_path }}/pterodactyl/panel/certs:/etc/letsencrypt/
            - {{ files.data_path }}/pterodactyl/panel/logs:/app/storage/logs
            - {{ files.data_path }}/pterodactyl/panel/mysql-no-ssl.cnf:/root/.my.cnf:ro
        environment:
            APP_URL: "{{ pterodactyl.app_url }}"
            APP_TIMEZONE: "{{ time }}"
            APP_SERVICE_AUTHOR: "{{ pterodactyl.app_service_author }}"
            TRUSTED_PROXIES: "*"
            APP_ENV: production
            APP_ENVIRONMENT_ONLY: "false"
            CACHE_DRIVER: redis
            SESSION_DRIVER: redis
            QUEUE_DRIVER: redis
            REDIS_HOST: cache
            DB_HOST: database
            DB_PORT: "3306"
            DB_DATABASE: "{{ pterodactyl.db_name }}"
            DB_USERNAME: "{{ pterodactyl.db_user }}"
            DB_PASSWORD: "{{ pterodactyl.db_password }}"

    wings:
        image: "ghcr.io/pterodactyl/wings:latest"
        container_name: pterodactyl-wings
        restart: unless-stopped
        privileged: true
        depends_on:
            - panel
        ports:
            - "{{ ports.wings_sftp }}:2022"
            - "{{ ports.wings_api }}:8080"
        tty: true
        environment:
            TZ: "{{ time }}"
            WINGS_UID: 988
            WINGS_GID: 988
            WINGS_USERNAME: pterodactyl
        volumes:
            - /var/run/docker.sock:/var/run/docker.sock
            - /var/lib/docker/containers/:/var/lib/docker/containers/
            - /etc/pterodactyl/:/etc/pterodactyl/
            - /var/lib/pterodactyl/:/var/lib/pterodactyl/
            - /var/log/pterodactyl/:/var/log/pterodactyl/
            - /tmp/pterodactyl/:/tmp/pterodactyl/

---
x-common-config: &default-service
    labels:
        - "deunhealth.restart.on.unhealthy=true"
    restart: unless-stopped

services:
    wg-dashboard:
        <<: *default-service
        image: "donaldzou/wgdashboard:latest"
        container_name: wg-dashboard
        cap_add:
            - NET_ADMIN
            - SYS_MODULE
        sysctls:
            - net.ipv4.ip_forward=1
            - net.ipv6.conf.all.forwarding=1
        ports:
            - {{ wgdashboard.port }}:10086
            - {{ wireguard.listen_port }}:51820/udp
        volumes:
            - /etc/wireguard:/etc/wireguard
            - {{ files.data_path }}/wg-dashboard:/opt/wireguarddashboard/app/db
        environment:
            - TZ={{ time }}
            - WGD_WELCOME_SESSION=false

    watchtower:
        <<: *default-service
        image: "nickfedor/watchtower:latest"
        container_name: watchtower
        environment:
            - TZ={{ time }}
        volumes:
            - {{ files.docker_sock }}:/var/run/docker.sock
        command: --cleanup=true --include-restarting=true --include-stopped=true --interval=86400
